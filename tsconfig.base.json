{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ausbildung/shared-core": ["packages/shared-core/src/index.ts"],
      "@ausbildung/plugin-kit": ["packages/plugin-kit/src/index.ts"]
    }
  }
}

